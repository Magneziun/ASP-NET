@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model List<Lesson2.Model.Meme>

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css" integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">
    <style>
            body {
                background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
                min-height: 100vh;
                padding: 40px 0;
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            }

            .container {
                max-width: 1400px;
                margin: 0 auto;
                padding: 20px;
            }

            .card-deck {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
                gap: 24px;
                padding: 0;
                margin: 0;
            }

                .card-deck .col-md-3,
                .card-deck .col-sm-6 {
                    flex: none;
                    max-width: 100%;
                    padding: 0;
                    margin: 0;
                }

            .card {
                border: none;
                border-radius: 20px;
                overflow: hidden;
                background-color: #1e1e2f;
                transition: transform 0.2s ease, box-shadow 0.2s ease;
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
                height: auto;
                display: flex;
                flex-direction: column;
            }

                .card:hover {
                    transform: translateY(-6px);
                    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.5);
                }

            .card-img-top {
                width: 100%;
                height: auto;
                object-fit: contain;
                background-color: #0a0a12;
                display: block;
            }

            .card-body {
                padding: 14px 16px 18px;
                display: flex;
                flex-direction: column;
                gap: 6px;
            }

            .card-title {
                font-size: 1.05rem;
                font-weight: 600;
                margin-bottom: 4px;
                color: #ffffff;
                line-height: 1.3;
            }

            .card-text {
                font-size: 0.85rem;
                color: #b0b0c0;
                margin-bottom: 4px;
            }

            .mem-age {
                font-weight: 500;
                color: #b77aff;
            }

            .card-body a {
                margin-top: 8px;
                font-size: 0.85rem;
                font-weight: 500;
                color: #b77aff;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 4px;
                transition: opacity 0.2s;
            }

                .card-body a:hover {
                    text-decoration: underline;
                    opacity: 0.8;
                    color: #d9a7ff;
                }
    </style>
</head>
<body>
    <div class="container">
        <div class="card-deck">
            @foreach (var mem in Model)
            {
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="card h-100">
                        <img class="card-img-top" src="@mem.PhotoSrc" alt="@mem.Name">
                        <div class="card-body">
                            <h5 class="card-title">@mem.Name</h5>
                            <p class="card-text mem-age">Рейтинг: @mem.Rating</p>
                            <p class="card-text">@string.Join(" ", mem.Description.Split(' ').Take(5))...</p>
                            <a asp-controller="Home" asp-action="Details" asp-route-id="@mem.Id">Детали</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.2.1.slim.min.js" integrity="sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.12.9/dist/umd/popper.min.js" integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/js/bootstrap.min.js" integrity="sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl" crossorigin="anonymous"></script>
</body>
</html>