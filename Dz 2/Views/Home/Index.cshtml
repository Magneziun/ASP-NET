@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model List<Lesson2.Model.Meme>

<style>
    /* Можно оставить стили для карточек, но лучше вынести в отдельный CSS-файл */
    .card-deck {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 24px;
        padding: 0;
        margin: 20px 0;
    }
    .card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        background-color: #1e1e2f;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
    }
    .card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 32px rgba(0, 0, 0, 0.5);
    }
    .card-img-top {
        width: 100%;
        height: auto;
        object-fit: contain;
        background-color: #0a0a12;
    }
    .card-body {
        padding: 14px 16px 18px;
    }
    .card-title {
        font-size: 1.05rem;
        font-weight: 600;
        color: #ffffff;
    }
    .card-text {
        font-size: 0.85rem;
        color: #b0b0c0;
    }
    .mem-age {
        font-weight: 500;
        color: #b77aff;
    }
    .card-body a {
        color: #b77aff;
        text-decoration: none;
    }
    .card-body a:hover {
        text-decoration: underline;
        color: #d9a7ff;
    }
</style>

<div class="card-deck">
    @foreach (var mem in Model)
    {
        <div class="card">
            <img class="card-img-top" src="@mem.PhotoSrc" alt="@mem.Name">
            <div class="card-body">
                <h5 class="card-title">@mem.Name</h5>
                <p class="card-text mem-age">Рейтинг: @mem.Rating</p>
                <p class="card-text">@string.Join(" ", mem.Description.Split(' ').Take(5))...</p>
                <a asp-controller="Home" asp-action="Details" asp-route-id="@mem.Id">Детали</a>
            </div>
        </div>
    }
</div>